{
  "$schema": "https://unpkg.com/knip@6/schema.json",
  "entry": [
    "electron/main/index.ts",
    "electron/preload/index.ts",
    "scripts/*.cjs"
  ],
  "project": [
    "electron/**/*.ts",
    "src/**/*.{ts,tsx}",
    "scripts/**/*.{ts,cjs,js}"
  ],
  "ignore": [
    "**/*.d.ts"
  ],
  "vite": {
    "config": ["electron.vite.config.ts"]
  },
  "vitest": {
    "config": ["vitest.config.ts"],
    "entry": ["tests/**/*.{test,spec}.{ts,tsx}"]
  }
}
