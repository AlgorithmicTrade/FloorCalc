{
  "$schema": "https://unpkg.com/knip@6/schema.json",
  "entry": [
    "src/main.tsx",
    "vite.config.ts",
    "vitest.config.ts"
  ],
  "project": [
    "src/**/*.{ts,tsx}"
  ],
  "ignore": [
    "**/*.d.ts"
  ],
  "vite": {
    "config": ["vite.config.ts"]
  },
  "vitest": {
    "config": ["vitest.config.ts"],
    "entry": ["tests/**/*.{test,spec}.{ts,tsx}"]
  }
}
