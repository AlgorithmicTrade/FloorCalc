{
  "name": "floorcalc",
  "version": "1.1.1",
  "private": true,
  "description": "FloorCalc — web-калькулятор расхода рулонных напольных и настенных покрытий",
  "type": "module",
  "packageManager": "npm@10.8.2",
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  },
  "scripts": {
    "dev": "vite",
    "build": "npm run typecheck && vite build",
    "preview": "vite preview",
    "typecheck": "tsc -p tsconfig.web.json --noEmit && tsc -p tsconfig.node.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "jspdf": "^4.2.1",
    "konva": "^9.3.16",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "zod": "^3.23.8",
    "zustand": "^5.0.2"
  },
  "devDependencies": {
    "@types/node": "^22.19.18",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "@vitejs/plugin-react": "^5.2.0",
    "knip": "^6.12.1",
    "typescript": "^5.6.3",
    "vite": "^7.3.3",
    "vitest": "^4.1.5"
  }
}
