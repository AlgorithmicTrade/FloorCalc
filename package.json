{
  "name": "floorcalc",
  "version": "1.0.9",
  "private": true,
  "description": "FloorCalc — desktop-калькулятор расхода рулонных напольных покрытий",
  "main": "out/main/index.js",
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "electron-vite dev",
    "build": "npm run typecheck && electron-vite build && electron-builder --config electron-builder.yml",
    "build:safe": "node scripts/build-safe.cjs",
    "build:publish": "npm run typecheck && electron-vite build && electron-builder --config electron-builder.yml --publish always",
    "typecheck": "tsc -p tsconfig.electron.json --noEmit && tsc -p tsconfig.web.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "preview": "electron-vite preview"
  },
  "dependencies": {
    "electron-updater": "^6.3.9",
    "jspdf": "^2.5.2",
    "konva": "^9.3.16",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-konva": "^19.2.3",
    "semver": "^7.6.3",
    "zod": "^3.23.8",
    "zustand": "^5.0.2"
  },
  "devDependencies": {
    "@types/node": "^20.17.10",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "@types/semver": "^7.5.8",
    "@vitejs/plugin-react": "^4.3.4",
    "electron": "^32.2.7",
    "electron-builder": "^25.1.8",
    "electron-vite": "^2.3.0",
    "typescript": "^5.6.3",
    "vite": "^5.4.11",
    "vitest": "^2.1.8"
  }
}
