{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "composite": true,
    "outDir": "out",
    "rootDir": ".",
    "lib": ["ES2022"],
    "types": ["node"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "baseUrl": ".",
    "paths": {
      "@shared/*": ["src/shared/*"]
    }
  },
  "include": [
    "electron/**/*.ts",
    "src/shared/**/*.ts",
    "src/domain/types.ts"
  ],
  "exclude": ["node_modules", "out", "release", "dist"]
}
